# ── Orion Consultant ──────────────────────────────────
# Server
ORION_HOST=0.0.0.0
ORION_PORT=8090
ORION_LOG_LEVEL=info

# Risk thresholds
ORION_MAX_DRAWDOWN=0.05
ORION_MAX_VOLATILITY=200.0

# External services (optional)
ORION_N8N_WEBHOOK_URL=http://localhost:5678/webhook
ORION_N8N_HEALTH_PATH=/healthz
ORION_N8N_AGENT_CHAT_ENABLED=false
ORION_N8N_AGENT_CHAT_WEBHOOK_PATH=/webhook/agent-chat
ORION_N8N_TRADING_DECISION_WEBHOOK_PATH=/webhook/trading-decision
ORION_N8N_TRADE_EXECUTED_WEBHOOK_PATH=/webhook/trade-executed
ORION_N8N_TRADE_CLOSED_WEBHOOK_PATH=/webhook/trade-closed
ORION_N8N_TRADING_ERROR_WEBHOOK_PATH=/webhook/trading-error
ORION_N8N_PERFORMANCE_METRICS_WEBHOOK_PATH=/webhook/performance-metrics
ORION_NOTIFICATION_TIMEOUT_SECONDS=10
ORION_JAVA_BOT_URL=http://localhost:8080
ORION_JAVA_PROCESS_EVENT_PATH=/api/n8n/process-event

# MCP
ORION_MCP_TRANSPORT=stdio

# LLM / AI Config
ORION_ENABLE_EXPERT_LLM=false
ORION_GROQ_API_KEY=your_groq_api_key_here
GROQ_API_KEY=your_groq_api_key_here
ORION_VIGILANTE_RAG_WEBHOOK_URL=http://localhost:5678/webhook/orion-vigilante-memory
